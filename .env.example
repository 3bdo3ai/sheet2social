# ==============================================
# Environment Variables Configuration
# ==============================================
# Copy this file to .env.local for development
# or configure these in your hosting platform
# ==============================================

# ----- Admin Authentication -----
# Password for accessing the admin panel at /admin
ADMIN_PASSWORD=your_secure_admin_password_here

# ----- Supabase Configuration -----
# Your Supabase project URL (found in Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase Anonymous Key (found in Project Settings > API)
# This is safe to expose in the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Supabase Service Role Key (found in Project Settings > API)
# ⚠️ KEEP THIS SECRET - Never expose in client-side code
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ----- Optional: Node Version -----
# Ensure compatibility with your hosting provider
# Current configuration uses Node 22.x (see package.json)

# ==============================================
# Notes:
# - All NEXT_PUBLIC_* variables are exposed to the browser
# - Service role key should ONLY be used in server-side API routes
# - For local development, use .env.local (not tracked in git)
# - For production, configure these in your hosting platform
# ==============================================
