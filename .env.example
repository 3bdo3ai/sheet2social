# Selenium / Chrome login settings
# Point directly at the cached chromedriver so Next.js server routes don't need
# to invoke selenium-manager.exe (which fails with a \ROOT path error).
CHROMEDRIVER_PATH=D:\Job\In Progress\Sheet2Social\drivers\chromedriver.exe
CHROME_BINARY_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
WORKER_DRY_RUN=false

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# License-based auth
LICENSE_SESSION_SECRET=replace_with_a_long_random_secret
# Optional: force cookie security behavior.
# true  -> always secure cookie (HTTPS only)
# false -> allow HTTP cookie (use only behind trusted private networks)
# If omitted, production auto-detects via x-forwarded-proto / request URL.
LICENSE_COOKIE_SECURE=

# Comma-separated list of license keys that are allowed to access /admin/licenses
# Example: LICENSE_ADMIN_KEYS=Ab3$Cd4%Ef5&Gh6*Ij7+Kl8-
LICENSE_ADMIN_KEYS=
