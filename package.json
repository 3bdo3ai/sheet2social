{
  "name": "sheet2social-control-center",
  "version": "2.2.0",
  "private": true,
  "main": "main.js",
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=\"--no-warnings=ExperimentalWarning\" node scripts/run-next.js dev",
    "dev:headless": "cross-env WORKER_VISIBLE_BROWSER=false NODE_OPTIONS=\"--no-warnings=ExperimentalWarning\" node scripts/run-next.js dev",
    "build": "cross-env NODE_OPTIONS=\"--no-warnings=ExperimentalWarning\" node scripts/run-next.js build",
    "start": "cross-env NODE_OPTIONS=\"--no-warnings=ExperimentalWarning\" node scripts/run-next.js start",
    "lint": "next lint",
    "worker:engine": "tsx worker/engine.ts",
    "worker:once": "tsx worker/engine.ts --once",
    "worker:visible": "cross-env WORKER_VISIBLE_BROWSER=true WORKER_VISUAL_TRACE=true WORKER_SKIP_PREFLIGHT_IN_VISIBLE_MODE=true WORKER_DEBUG_BROWSER_HOLD_FAILURE_ONLY=true WORKER_DEBUG_BROWSER_HOLD_MS=0 tsx worker/engine.ts",
    "comment:test": "tsx scripts/comment-test.ts",
    "license:bootstrap": "tsx scripts/bootstrap-license-admin.ts",
    "web:dev": "cross-env NODE_OPTIONS=\"--no-warnings=ExperimentalWarning\" node scripts/run-next.js dev",
    "web:build": "cross-env NODE_OPTIONS=\"--no-warnings=ExperimentalWarning\" node scripts/run-next.js build",
    "copy:standalone": "node scripts/copy-standalone-files.js",
    "electron:dev": "node scripts/run-electron.js dev",
    "electron:start": "npm run web:build && node scripts/run-electron.js start",
    "electron:build": "npm run web:build && npm run copy:standalone && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win nsis",
    "build:exe": "npm run web:build && npm run copy:standalone && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win nsis"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "build": {
    "appId": "com.sheet2social.app",
    "productName": "Sheet2Social Control Center",
    "artifactName": "${productName} Setup ${version}.${ext}",
    "executableName": "Sheet2SocialControlCenter",
    "asar": true,
    "asarUnpack": [
      "dist/electron-resources/**"
    ],
    "directories": {
      "output": "dist/release"
    },
    "files": [
      "main.js",
      "preload.js",
      "package.json",
      "dist/electron-resources/**/*",
      "!node_modules/**/*",
      "!.next/**/*",
      "!src/**/*",
      "!worker/**/*",
      "!dist/release/**/*"
    ],
    "win": {
      "icon": "public/favicon.ico",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "Sheet2Social Control Center",
      "uninstallDisplayName": "Sheet2Social Control Center",
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "include": "build/installer.nsh",
      "installerIcon": "public/favicon.ico",
      "uninstallerIcon": "public/favicon.ico",
      "installerHeaderIcon": "public/favicon.ico",
      "installerSidebar": "public/Logo.png",
      "uninstallerSidebar": "public/Logo.png"
    },
    "extraResources": []
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@supabase/supabase-js": "^2.103.0",
    "autoprefixer": "^10.4.21",
    "csv-parser": "^3.2.0",
    "csv-writer": "^1.6.0",
    "googleapis": "^171.4.0",
    "lucide-react": "^1.8.0",
    "next": "^16.2.1",
    "otpauth": "^9.5.0",
    "parquetjs-lite": "^0.8.7",
    "proxy-chain": "^2.7.1",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "selenium-webdriver": "^4.43.0",
    "tailwindcss-rtl": "^0.9.0"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/selenium-webdriver": "^4.35.5",
    "cross-env": "^10.1.0",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "^16.2.1",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
